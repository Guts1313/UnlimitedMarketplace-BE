# Copy this file to .env and fill in real values. .env is git-ignored.
# Used by docker-compose and by the Spring Boot app (env vars override application.properties).

# --- Database ---
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/unlimitedmarketplace?useSSL=false&allowPublicKeyRetrieval=true
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=change-me
MYSQL_DATABASE=unlimitedmarketplace
MYSQL_ROOT_PASSWORD=change-me

# --- Spring Security default user ---
SPRING_SECURITY_USER_NAME=user
# BCrypt-encoded password
SPRING_SECURITY_USER_PASSWORD=change-me

# --- JWT ---
# Base64-encoded HMAC secret key (generate your own, e.g. `openssl rand -base64 48`)
JWT_SECRET=replace-with-base64-encoded-secret
JWT_EXPIRATION=60

# --- Server ---
SERVER_PORT=8080
